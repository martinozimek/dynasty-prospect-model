# Environment / secrets — NEVER commit these
.env

# Claude Code local settings
.claude/

# Training data (generated — too large for git)
data/*
!data/.gitkeep

# Fitted model artifacts (regenerate via scripts/fit_model.py --all)
model/*
!model/.gitkeep
models/*
!models/.gitkeep

# Generated report PDFs and scored output (regenerate via scripts)
output/reports/*.pdf
output/scores/*.csv

# Generated dashboard HTML (large artifact — regenerate via scripts/export_dashboard.py)
dashboard/*.html

# Raw database file (lives in cfb-prospect-db repo)
ff.db

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
